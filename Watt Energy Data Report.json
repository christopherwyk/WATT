    {
      "parameters": {
        "jsCode": "const report = $input.item.json.content[0].text;\n\nconst binaryData = await this.helpers.prepareBinaryData(\n  Buffer.from(report, 'utf8'),\n  'energy-report.md',\n  'text/markdown'\n);\n\nreturn {\n  json: {\n    generated_at: new Date().toISOString()\n  },\n  binary: {\n    data: binaryData\n  }\n};"
      },
