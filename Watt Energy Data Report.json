          "value": "claude-sonnet-4-20250514",
          "mode": "list",
          "cachedResultName": "claude-sonnet-4-20250514"
        },
        "messages": {
          "values": [
            {
              "content": "=I have the following JSON data containing live UK energy tariffs for the North West region retrieved today from the Octopus Energy API. Analyse this data and write a 1000-word consumer report.\n\nDATA:\n{{ $json.tariff_data }}\n\nYour report must:\n- Use ONLY the exact pence figures in the data above\n- Compare unit rates and standing charges across all tariffs\n- Calculate estimated annual costs assuming 3,100 kWh electricity and 12,000 kWh gas\n- Assess contract flexibility and exit fees\n- Note which tariffs are green energy\n- End with a numbered top 3 recommendation\n\nWrite the report now. Do not explain how to build a system. Just write the report.\n"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        -80,
        144
      ],
      "id": "74e29d35-a3e2-442a-9c6e-8d926c288158",
      "name": "Message a model",
      "credentials": {
        "anthropicApi": {
          "id": "bVM89qjoEctWfrZf",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\n\nreturn {\n  json: {\n    tariff_data: JSON.stringify(items, null, 2)\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
