    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\nconst elec = item.single_register_electricity_tariffs?._H?.direct_debit_monthly;\nconst gas = item.single_register_gas_tariffs?._H?.direct_debit_monthly;\n\nreturn {\n  json: {\n    supplier: item.brand,\n    plan_name: item.display_name,\n    code: item.code,\n    is_variable: item.is_variable,\n    is_green: item.is_green,\n    exit_fee: elec?.exit_fees_inc_vat ?? 0,\n    elec_unit_rate_p: elec?.standard_unit_rate_inc_vat ?? null,\n    elec_standing_charge_p: elec?.standing_charge_inc_vat ?? null,\n    gas_unit_rate_p: gas?.standard_unit_rate_inc_vat ?? null,\n    gas_standing_charge_p: gas?.standing_charge_inc_vat ?? null,\n    fetched_at: new Date().toISOString()\n  }\n};"
      },
